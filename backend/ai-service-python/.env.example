# Python AI service config — copy to `.env`
# Use the key for whichever provider you implement in lib/llm.py
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
# OPENROUTER_API_KEY=...   # route through OpenRouter to keep the provider swappable

MODEL=claude-sonnet-5
TRANSLATION_DB_PATH=translations.db

# Bonus/optional: 0 (default) = cache entries never expire, which is the
# assignment's required behavior. Set to a number of seconds to opt into TTL
# expiry. POST /clear-cache wipes the cache on demand regardless of this.
CACHE_TTL_SECONDS=0
